# ============================================================
# AlNao Sh Control Room - Configuration File
# ============================================================
# Format:
#   MONITOR_<N>=<label>|<url_with_port>
#   TAB_<N>=<tab_label>
#   TAB_<N>_SCRIPT_<M>=<button_label>|<absolute_path_to_sh>
# ============================================================

# --- Status Monitors (header bar indicators) ---
MONITOR_1=Backend|http://localhost:8042
MONITOR_2=Admin|http://localhost:5172
MONITOR_3=Website|http://localhost:5174
MONITOR_4=Cloud API|http://test.domain.com

# --- Refresh interval for status monitors (seconds) ---
MONITOR_REFRESH_SECONDS=30

# --- Tab definitions ---
TAB_1=Backend Services
TAB_1_SCRIPT_1=Start Backend|/mnt/Dati4/scripts/start_backend.sh
TAB_1_SCRIPT_2=Stop Backend|/mnt/Dati4/scripts/stop_backend.sh
TAB_1_SCRIPT_3=Rebuild Backend|/mnt/Dati4/scripts/rebuild_backend.sh

TAB_2=Frontend
TAB_2_SCRIPT_1=Start Admin|/mnt/Dati4/scripts/start_admin.sh
TAB_2_SCRIPT_2=Start Website|/mnt/Dati4/scripts/start_website.sh

TAB_3=Deploy & Infra
TAB_3_SCRIPT_1=Deploy Staging|/mnt/Dati4/scripts/deploy_staging.sh
TAB_3_SCRIPT_2=DB Migration|/mnt/Dati4/scripts/db_migrate.sh
TAB_3_SCRIPT_3=Health Check|/mnt/Dati4/scripts/health_check.sh
TAB_3_SCRIPT_4=Tail Logs|/mnt/Dati4/scripts/tail_logs.sh
