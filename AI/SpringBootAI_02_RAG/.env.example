# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8081

# ── Database ──────────────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/vectordb
DB_USERNAME=postgres
DB_PASSWORD=changeme

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5500,http://localhost:3000

# ── Security ──────────────────────────────────────────────────────────────────
# Lasciare vuoto per disabilitare l'autenticazione in locale
API_KEY=changeme

# ── RAG ───────────────────────────────────────────────────────────────────────
# Soglia di similarità coseno (0.0–1.0): chunk sotto soglia vengono scartati
RAG_SIMILARITY_THRESHOLD=0.65
# Dimensione chunk in token
RAG_CHUNK_SIZE=512
# Caratteri minimi prima di uno split a fine frase (overlap approssimativo)
RAG_CHUNK_OVERLAP=64
